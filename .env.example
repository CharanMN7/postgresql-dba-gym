# PostgreSQL DBA Gym — environment variables
#
# Copy this file to `.env` and fill in real values. `inference.py` reads
# these at startup. `demo.py` only needs ENV_URL.
#
# docker-compose.yml loads this file via `env_file: .env`, so every var
# below is injected into the `server` container at runtime. Nothing is
# baked into the image — secrets stay on the host.

# --- OpenAI endpoint (required for inference.py) ---------------------------
# OpenAI API base URL. The hackathon mandates OpenAI-compatible usage.
API_BASE_URL=https://api.openai.com/v1

# OpenAI model id passed to client.chat.completions.create().
MODEL_NAME=gpt-4o-mini

# Your OpenAI API key. The environment variable name is `HF_TOKEN` per the
# hackathon spec — its VALUE is the OpenAI API key (starts with `sk-`).
HF_TOKEN=sk-your-openai-api-key-here

# --- Environment endpoint --------------------------------------------------
# Base URL of the running pg-dba-gym server. Default is the local Docker
# port. For evaluating a deployed Space, set this to its public URL:
#     ENV_URL=https://your-username-pg-dba-gym.hf.space
ENV_URL=http://localhost:8000

# --- Judge-only (optional) -------------------------------------------------
# When set, inference.py spins up a fresh container via
# `GenericEnvClient.from_docker_image(IMAGE_NAME)` instead of connecting
# to ENV_URL. This is the path the hackathon judge uses.
# IMAGE_NAME=pg-dba-gym
